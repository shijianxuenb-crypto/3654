page {
  min-height: 100%;
  background: #f6f5ff;
  color: #25233a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
}

view, text, input, button, textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  border-radius: 0;
  background: transparent;
}

button::after {
  border: 0;
}
